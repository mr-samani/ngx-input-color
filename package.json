{
  "name": "ngx-input-color",
  "version": "5.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open --port=3600",
    "build": "ng build demo",
    "watch": "ng build --watch --configuration development",
    "build:lib": "ng build ngx-input-color",
    "publish:npm": "cd dist/ngx-input-color && npm publish",
    "copy-readme": "copy projects\\library\\README.md projects\\storybook\\README.imported.md",
    "storybook": "npm run copy-readme && ng run ngx-input-color:storybook",
    "compdoc:serve": "compodoc -p tsconfig.compodoc.json -s",
    "compdoc:exportJson": "compodoc -p tsconfig.compodoc.json -e --exportFormat json",
    "build-storybook": "npm run copy-readme  && ng run ngx-input-color:build-storybook && npm run copyScreenShot",
    "copyScreenShot": "copy projects\\storybook\\src\\assets\\screenshot.jpg docs\\screenshot.jpg",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.3",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.0.7",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.0.3",
    "@angular/platform-browser": "^21.0.3",
    "@angular/platform-browser-dynamic": "^21.0.3",
    "@angular/router": "^21.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.0.3",
    "@compodoc/compodoc": "^1.1.32",
    "@storybook/addon-docs": "^10.1.4",
    "@storybook/angular": "^10.1.4",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "ng-packagr": "^21.0.0",
    "storybook": "^10.1.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  }
}
