{
  "name": "ngx-input-color",
  "version": "6.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open --port=3600",
    "build": "ng build demo",
    "watch": "ng build --watch --configuration development",
    "build:lib": "ng build ngx-input-color",
    "publish:npm": "cd dist/ngx-input-color && npm publish",
    "copy-readme": "copy projects\\library\\README.md projects\\storybook\\README.imported.md",
    "storybook": "npm run copy-readme && ng run ngx-input-color:storybook",
    "compdoc:serve": "compodoc -p tsconfig.compodoc.json -s",
    "compdoc:exportJson": "compodoc -p tsconfig.compodoc.json -e --exportFormat json",
    "build-storybook": "npm run copy-readme  && ng run ngx-input-color:build-storybook && npm run copyScreenShot",
    "copyScreenShot": "copy projects\\storybook\\src\\assets\\screenshot.jpg docs\\screenshot.jpg",
    "test": "ng test --ui",
    "test:demo": "ng test demo --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=junit --outputFile=./coverage/junit.xml"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^22.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@compodoc/compodoc": "^1.1.16",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/angular": "^10.3.5",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "jsdom": "^27.1.0",
    "ng-packagr": "^22.0.0",
    "storybook": "^10.1.4",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  }
}
